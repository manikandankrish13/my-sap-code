* Read RAP entities
    READ ENTITIES OF zr_dtshipment_det
        IN LOCAL MODE
        ENTITY zrdtshipmentdet
        ALL FIELDS
        WITH CORRESPONDING #( keys )
        RESULT DATA(lt_data).

    LOOP AT lt_data INTO DATA(ls_data).

* Build AI prompt using shipment data
      lv_prompt = |Shipment from { ls_data-originlocation } to { ls_data-destinationlocation }. |
                  && |Delay hours: { ls_data-delayhours }. |
                  && |Weather: { ls_data-currentstatus }. |
                  && |Provide logistics delay risk analysis.|.

*------------------------------------------------------------------
* Create HTTP Destination
*------------------------------------------------------------------

      TRY.
          lo_http_dest = cl_http_destination_provider=>create_by_url(
            i_url = 'https://api.openai.com'
          ).
        CATCH cx_http_dest_provider_error.
          RETURN.
      ENDTRY.

*------------------------------------------------------------------
* Create HTTP Client
*------------------------------------------------------------------

      TRY.
          lo_client = cl_web_http_client_manager=>create_by_http_destination(
            lo_http_dest ).
        CATCH cx_web_http_client_error.
          RETURN.
      ENDTRY.

*------------------------------------------------------------------
* API Endpoint
*------------------------------------------------------------------

      lo_client->get_http_request( )->set_uri_path(
      '/v1/chat/completions'
      ).
*----------------------------------------------------------------
* Prepare Request
*----------------------------------------------------------------
      lo_request = lo_client->get_http_request( ).

      lo_request->set_uri_path( '/v1/chat/completions' ).

      TRY.
          lo_response = lo_client->execute( if_web_http_client=>post ).
        CATCH cx_web_http_client_error.
          "handle exception
      ENDTRY.

*------------------------------------------------------------------
* Headers
*------------------------------------------------------------------

      lo_client->get_http_request( )->set_header_field(
        i_name  = 'Content-Type'
        i_value = 'application/json'
      ).

      lo_client->get_http_request( )->set_header_field(
        i_name  = 'Authorization'
        i_value = |Bearer { lv_api_key }|
      ).

*------------------------------------------------------------------
* Build JSON request safely
*------------------------------------------------------------------
      DATA(ls_request) = VALUE ty_request(
        model = 'gpt-4o-mini'
        messages = VALUE #( (
            role = 'user'
            content = lv_prompt
        ) )
      ).

      /ui2/cl_json=>serialize(
        EXPORTING data = ls_request
        pretty_name = /ui2/cl_json=>pretty_mode-camel_case
        RECEIVING r_json = lv_body
      ).

      lo_client->get_http_request( )->set_text( lv_body ).

*------------------------------------------------------------------
* Execute API call
*------------------------------------------------------------------

      TRY.
          lo_response = lo_client->execute( if_web_http_client=>post ).
        CATCH cx_web_http_client_error.
          RETURN.
      ENDTRY.

*------------------------------------------------------------------
* Get response JSON
*------------------------------------------------------------------

      lv_json = lo_response->get_text( ).

*------------------------------------------------------------------
* Parse OpenAI response
*------------------------------------------------------------------

      DATA(ls_response) = VALUE ty_response( ).

      /ui2/cl_json=>deserialize(
        EXPORTING json = lv_json
        CHANGING  data = ls_response
      ).

      READ TABLE ls_response-choices INDEX 1 INTO DATA(ls_choice).

      DATA : lv_ai_result TYPE string.

      IF sy-subrc = 0.
        lv_ai_result = ls_choice-message-content.
      ENDIF.

*----------------------------------------------------------------
* Show Popup Message in Fiori
*----------------------------------------------------------------
      APPEND VALUE #(
        %tky = ls_data-%tky
        %msg = new_message_with_text(
                 severity = if_abap_behv_message=>severity-information
                 text     = lv_ai_result )
      ) TO reported-zrdtshipmentdet.

*------------------------------------------------------------------
* Update RAP entity with AI result
*------------------------------------------------------------------

*      MODIFY ENTITIES OF zr_dtshipment_det
*        IN LOCAL MODE
*        ENTITY zrdtshipmentdet
*        UPDATE
*        FIELDS ( AiResponse )
*        WITH VALUE #(
*          ( shipmentid = ls_data-shipmentid
*            AiResponse  = lv_ai_result )
*        ) REPORTED reported.

      MODIFY ENTITIES OF zr_dtshipment_det IN LOCAL MODE
        ENTITY zrdtshipmentdet
        UPDATE FIELDS ( airesponse )
        WITH VALUE #(
          FOR key IN keys
          ( %tky = key-%tky
            airesponse = lv_ai_result
          )
        )
        REPORTED DATA(ls_reported).

*------------------------------------------------------------------
* Return result to UI
*------------------------------------------------------------------

      APPEND VALUE #(
          %tky = ls_data-%tky
      ) TO lt_results.

    ENDLOOP.

    IF lt_results IS NOT INITIAL.
      result = lt_results.
    ENDIF.

  ENDMETHOD.


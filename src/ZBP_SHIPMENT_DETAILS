  METHOD calculate_delay_risk.

    DATA : lt_update TYPE TABLE FOR UPDATE zr_dtshipment_det.

    READ ENTITIES OF zr_dtshipment_det IN LOCAL MODE
    ENTITY zrdtshipmentdet
    ALL FIELDS WITH CORRESPONDING #( keys )
    RESULT DATA(lt_shipment_det).

    LOOP AT lt_shipment_det ASSIGNING FIELD-SYMBOL(<ls_shipment_det>).
      DATA(lv_risk) = <ls_shipment_det>-delayrisk.
      DATA(lv_crit) = <ls_shipment_det>-delayriskcrit.

      IF <ls_shipment_det>-delayrisk IS INITIAL OR <ls_shipment_det>-delayhours <= 8.
        lv_risk = 'ON_TRACK'.
        lv_crit = 3.
      ELSEIF <ls_shipment_det>-delayhours <= 24.
        lv_risk = 'AT_RISK'.
        lv_crit = 2.
      ELSE.
        lv_risk = 'DELAYED'.
        lv_crit = 1.
      ENDIF.

      IF lv_risk <> <ls_shipment_det>-delayrisk OR lv_crit <> <ls_shipment_det>-delayriskcrit.
        APPEND VALUE #(
        %tky = <ls_shipment_det>-%tky
        delayrisk = lv_risk
        delayriskcrit = lv_crit
        ) TO lt_update.
      ENDIF.
    ENDLOOP.

    IF  lt_update IS NOT INITIAL.
      MODIFY ENTITIES OF zr_dtshipment_det IN LOCAL MODE
      ENTITY zrdtshipmentdet
      UPDATE FIELDS ( delayrisk delayriskcrit )
      WITH lt_update.
    ENDIF.

    reported-zrdtshipmentdet =  VALUE #(
      ( %msg = new_message_with_text(
*            %tky = <ls_shipment_det>-%tky
            severity = if_abap_behv_message=>severity-success
            text     = 'Delay Risk Calculated Successfully'
        )
      ) ).
  ENDMETHOD.

